<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Pod_Turnaround_Time_Days__c</fullName>
    <description>Represents the time between the pod being shipped to the patient and being returned back and placed into inventory</description>
    <externalId>false</externalId>
    <formula>IF(OR(ISBLANK(Data_Upload_Date__c), ISBLANK(Packaged_Date__c)), NULL,  Date_Received_by_Huxley__c  - Packaged_Date__c)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Pod Turnaround Time (Days)</label>
    <precision>18</precision>
    <required>false</required>
    <scale>1</scale>
    <trackHistory>false</trackHistory>
    <type>Number</type>
    <unique>false</unique>
</CustomField>
