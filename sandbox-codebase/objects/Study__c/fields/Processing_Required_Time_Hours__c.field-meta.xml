<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Processing_Required_Time_Hours__c</fullName>
    <description>Represents the amount of time processing has been required</description>
    <externalId>false</externalId>
    <formula>IF(ISBLANK(Data_Upload_Date__c), NOW() - Date_Received_by_Huxley__c, Data_Upload_Date__c - Date_Received_by_Huxley__c)*24</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Processing Required Time (Hours)</label>
    <precision>18</precision>
    <required>false</required>
    <scale>1</scale>
    <trackHistory>false</trackHistory>
    <type>Number</type>
    <unique>false</unique>
</CustomField>
