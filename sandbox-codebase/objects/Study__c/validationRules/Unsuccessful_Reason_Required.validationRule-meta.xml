<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Unsuccessful_Reason_Required</fullName>
    <active>true</active>
    <errorConditionFormula>AND ( ISPICKVAL (Study_Success_Status__c, &quot;Unsuccessful&quot;),  ISPICKVAL(Unsuccessful_Reason__c, &quot;&quot;))</errorConditionFormula>
    <errorMessage>Assign an Unsuccessful Reason for Unsuccessful Studies</errorMessage>
</ValidationRule>
