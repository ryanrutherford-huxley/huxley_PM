<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Percent_of_Billable_Orders__c</fullName>
    <formula>IF(ISBLANK(Number_of_Completed_Orders__c),0,Number_of_Billable_Orders__c / Number_of_Completed_Orders__c)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Percent of Billable Orders</label>
    <precision>18</precision>
    <required>false</required>
    <scale>1</scale>
    <trackHistory>false</trackHistory>
    <type>Percent</type>
</CustomField>
