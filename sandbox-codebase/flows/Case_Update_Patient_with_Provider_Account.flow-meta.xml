<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>65.0</apiVersion>
    <description>Used to populate the Provider Account on the Patient record in order to use the facility&apos;s name in a Mogli SMS Template for automated SMS messaging.
https://basecamp.com/2583453/projects/19794483/todos/515178473</description>
    <environments>Default</environments>
    <interviewLabel>(Case) Update Patient with Provider Account {!$Flow.CurrentDateTime}</interviewLabel>
    <label>(Case) Update Patient with Provider Account</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <description>Populate the Patient record with the Provider Account defined on the Case (Patient Order)</description>
        <name>Update_Patient_Record</name>
        <label>Update Patient Record</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.AccountId</elementReference>
            </value>
        </filters>
        <inputAssignments>
            <field>Provider_Account__pc</field>
            <value>
                <elementReference>$Record.Provider_Account__c</elementReference>
            </value>
        </inputAssignments>
        <object>Account</object>
    </recordUpdates>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Update_Patient_Record</targetReference>
        </connector>
        <filterFormula>{!$Record.Account.IsPersonAccount} = True &amp;&amp;
OR(
ISNEW() &amp;&amp; NOT(ISBLANK({!$Record.Provider_Account__c})),
ISCHANGED({!$Record.Provider_Account__c})
)</filterFormula>
        <object>Case</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
    <triggerOrder>500</triggerOrder>
</Flow>
