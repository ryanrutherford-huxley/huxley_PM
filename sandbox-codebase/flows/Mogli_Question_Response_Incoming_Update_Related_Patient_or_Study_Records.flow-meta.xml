        <filters>
            <field>Status__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>New</stringValue>
            </value>
        </filters>
        <filters>
            <field>Patient__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.Mogli_SMS__Mogli_Response__r.Mogli_SMS__Contact__r.AccountId</elementReference>
            </value>
        </filters>
        <inputAssignments>
            <field>Address_Confirmed_Date__c</field>
