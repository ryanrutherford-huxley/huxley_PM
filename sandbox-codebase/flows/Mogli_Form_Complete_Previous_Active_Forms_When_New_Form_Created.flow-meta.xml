                <value>
                    <elementReference>Get_Open_Forms[$EachItem].Id</elementReference>
                </value>
            </transformValueActions>
            <transformValueActions>
                <outputFieldApiName>Mogli_SMS__Status__c</outputFieldApiName>
                <transformType>Map</transformType>
                <value>
                    <stringValue>Completed</stringValue>
                </value>
            </transformValueActions>
        </transformValues>
    </transforms>
</Flow>
