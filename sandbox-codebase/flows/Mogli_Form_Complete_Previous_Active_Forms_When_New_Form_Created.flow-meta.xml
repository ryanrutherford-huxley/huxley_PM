    </recordUpdates>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Get_Open_Forms</targetReference>
        </connector>
        <object>Mogli_SMS__Form__c</object>
        <recordTriggerType>Create</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
    <transforms>
        <description>Assign Status = Complete</description>
        <name>Transform_Open_Mogli_Forms</name>
