    <decisions>
        <description>Verify that the patient has not already initiated a return</description>
        <name>Decision_Check_Date_Return_Initiated_Cellular_Upload_Completed</name>
        <label>Decision: Check Date Return Initiated &amp; Cellular Upload Completed</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Default Outcome: Return Was Already Initiated</defaultConnectorLabel>
        <rules>
            <name>Outcome_Return_Not_Initiated</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Date_Return_Initiated__c</leftValueReference>
                <operator>IsBlank</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Cellular_Upload_Complete__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Return_Instructions_Template</targetReference>
            </connector>
            <label>Outcome: Return Not Initiated</label>
        </rules>
    </decisions>
    <decisions>
        <description>In some cases, maybe the Expected Study Date is updated to be the same date as when the field was updated</description>
        <name>Decision_Same_day_or_In_Advance</name>
