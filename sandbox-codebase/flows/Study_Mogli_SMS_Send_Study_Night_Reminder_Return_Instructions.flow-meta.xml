    <environments>Default</environments>
    <formulas>
        <description>Used to enrich the SMS message with details about the Mogli template used</description>
        <name>formula_ReturnInstruction_TemplateDetails</name>
        <dataType>String</dataType>
        <expression>{!Get_Return_Instructions_Template.Mogli_SMS__Name__c} &amp; &quot;, &quot; &amp; {!Get_Return_Instructions_Template.Id}</expression>
    </formulas>
    <formulas>
        <description>Evaluates whether the calculated scheduled date (9AM on the Expected Study Date) is before the Flow&apos;s trigger date time</description>
        <name>formula_ScheduledDateLessThanNow</name>
        <dataType>Boolean</dataType>
        <expression>{!formula_ScheduledDateTime} &lt; {!$Flow.CurrentDateTime}</expression>
    </formulas>
    <formulas>
        <description>Send the SMS at 14:00 GMT time. (9 AM EST)</description>
        <name>formula_ScheduledDateTime</name>
        <dataType>DateTime</dataType>
        <expression>DATETIMEVALUE(TEXT(DATEVALUE({!$Record.Expected_Study_Date__c}))&amp;&quot; 14:00:00&quot;)</expression>
    </formulas>
    <formulas>
        <description>Send the SMS in 1 minutes if the Expected Study Date is the same date as TODAY()</description>
        <name>formula_SendSMSNow</name>
        <dataType>DateTime</dataType>
        <expression>{!$Flow.CurrentDateTime} + (1/1440)</expression>
    </formulas>
    <formulas>
        <name>formula_TemplateDetails</name>
        <dataType>String</dataType>
        <expression>{!Get_Study_Night_Reminder_Template.Mogli_SMS__Name__c} &amp; &quot;, &quot; &amp; {!Get_Study_Night_Reminder_Template.Id}</expression>
    </formulas>
    <interviewLabel>(Study) Mogli SMS Send Study Night Reminder &amp; Return Instructions {!$Flow.CurrentDateTime}</interviewLabel>
