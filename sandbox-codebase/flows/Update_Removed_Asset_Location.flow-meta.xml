<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>62.0</apiVersion>
    <description>If the Asset Listed for a particular study is deleted or changed for any reason, update its location and its study count metrics if needed</description>
    <environments>Default</environments>
    <formulas>
        <name>formula_isNew</name>
        <dataType>Boolean</dataType>
        <expression>ISNEW()</expression>
    </formulas>
    <formulas>
        <name>IncrementNumberofUses</name>
        <dataType>Number</dataType>
        <expression>IF(ISNULL({!AssetNumberofUses}), 1, {!AssetNumberofUses} + 1)</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <name>IncrementSuccessfulStudyCount</name>
        <dataType>Number</dataType>
        <expression>IF(ISNULL({!AssetSuccessfulStudyCount}), 1, {!AssetSuccessfulStudyCount} + 1)</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <name>IncrementUnsuccessfulStudyCount</name>
        <dataType>Number</dataType>
        <expression>IF(ISNULL({!AssetUnsuccessfulStudyCount}), 1, {!AssetUnsuccessfulStudyCount} + 1)</expression>
        <scale>0</scale>
    </formulas>
    <interviewLabel>Update Removed Asset Location {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Update Removed Asset Location</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <name>Change_Pod_Location_Back_to_Huxley</name>
        <label>Change Pod Location Back to Huxley</label>
        <locationX>176</locationX>
        <locationY>323</locationY>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record__Prior.Asset__c</elementReference>
            </value>
        </filters>
        <inputAssignments>
            <field>Asset_Location__c</field>
            <value>
                <stringValue>Huxley</stringValue>
            </value>
        </inputAssignments>
        <object>Asset</object>
    </recordUpdates>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Change_Pod_Location_Back_to_Huxley</targetReference>
        </connector>
        <filterFormula>AND(NOT(ISNULL({!$Record__Prior.Asset__c})), ISCHANGED({!$Record.Asset__c}))</filterFormula>
        <object>Study__c</object>
        <recordTriggerType>Update</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
    <variables>
        <name>AssetNumberofUses</name>
        <dataType>Number</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
        <scale>0</scale>
    </variables>
    <variables>
        <name>AssetSuccessfulStudyCount</name>
        <dataType>Number</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
        <scale>0</scale>
    </variables>
    <variables>
        <name>AssetUnsuccessfulStudyCount</name>
        <dataType>Number</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
        <scale>0</scale>
    </variables>
</Flow>
